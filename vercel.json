{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 30
      }
    }
  ],
  "routes": [
    {
      "src": "/ping",
      "dest": "index.js"
    },
    {
      "src": "/api/warmup",
      "dest": "index.js"
    },
    {
      "src": "/api/customers/import",
      "dest": "index.js",
      "headers": {
        "x-vercel-timeout": "60"
      }
    },
    {
      "src": "/api/(.*)",
      "dest": "index.js"
    },
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
