{
  "name": "aplnatlog-backend",
  "version": 2,
  "builds": [
    {
      "src": "restart-server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "restart-server.js"
    }
  ],
  "github": {
    "enabled": true,
    "silent": true
  },
  "env": {
    "NODE_ENV": "production"
  }
}
